---
// Product announcement banner - can be removed or updated for future announcements
---

<div id="announcement-banner" class="fixed top-0 left-0 right-0 z-[60] bg-primary-600 text-white py-2.5 px-4">
  <div class="max-w-6xl mx-auto flex items-center justify-center gap-2 text-sm">
    <span class="font-semibold">New:</span>
    <span>
      Introducing <a href="https://shipstry.com/" target="_blank" rel="noopener noreferrer" class="underline hover:no-underline font-medium">Shipstry</a> — a product ship registry for makers and early adopters.
    </span>
    <a
      href="https://shipstry.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="ml-2 inline-flex items-center gap-1 px-3 py-1 bg-white/20 hover:bg-white/30 rounded-full text-xs font-medium transition-colors"
    >
      Check it out
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
      </svg>
    </a>
  </div>
  <button
    id="close-announcement"
    class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-white/20 rounded transition-colors"
    aria-label="Close announcement"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>

<script>
  const banner = document.getElementById('announcement-banner');
  const closeBtn = document.getElementById('close-announcement');
  const header = document.getElementById('main-header');

  const adjustHeader = (show: boolean) => {
    if (header) {
      header.style.top = show ? '44px' : '0';
    }
  };

  // Check if banner was previously closed
  if (sessionStorage.getItem('announcement-closed')) {
    banner?.remove();
    adjustHeader(false);
  } else {
    adjustHeader(true);
  }

  closeBtn?.addEventListener('click', () => {
    banner?.classList.add('hidden');
    sessionStorage.setItem('announcement-closed', 'true');
    adjustHeader(false);
  });
</script>
